# ─────────────────────────────────────────────────────────
# VOLLEYBALL LIVE SCORER — Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env to GitHub — it is already in .gitignore.
# ─────────────────────────────────────────────────────────

# PostgreSQL connection string from Neon dashboard
# Use the POOLED connection string (ends in -pooler.neon.tech)
DATABASE_URL=postgresql://username:password@ep-example-pooler.us-west-2.aws.neon.tech/neondb?sslmode=require

# Secret key for Flask session encryption
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-long-random-secret-key
